FROM python:3.11-slim AS builder

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev gcc \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install --no-cache-dir --target=/app/deps -e .

FROM python:3.11-slim

RUN useradd --create-home --shell /bin/bash humetric

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /app/deps /usr/local/lib/python3.11/site-packages
COPY pyproject.toml .
COPY src/ src/
COPY packs/ packs/
COPY prompts/ prompts/

RUN pip install --no-cache-dir -e . && chown -R humetric:humetric /app

USER humetric

EXPOSE 8002

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8002/healthz')" || exit 1

CMD ["uvicorn", "humetric.api:app", "--host", "0.0.0.0", "--port", "8002", "--workers", "4"]
