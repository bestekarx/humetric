# PostgreSQL + pgvector (admin role — migration/seed)
DATABASE_URL=postgresql+psycopg://humetric:humetric@localhost:5434/humetric

# PostgreSQL + pgvector (restricted role — runtime, RLS active)
DATABASE_URL_APP=postgresql+psycopg://humetric_app:humetric_app@localhost:5434/humetric

# humetric_app role password. Migration 001 creates the role with this value
# (dev default: humetric_app). PRODUCTION: set a strong URL-safe password
# BEFORE the first `alembic upgrade head`; on an existing DB rotate with
# `psql "$DATABASE_URL" -f scripts/create_app_role.sql` and update
# DATABASE_URL_APP to match.
HUMETRIC_APP_DB_PASSWORD=humetric_app

# Anthropic (LLM agents — used in Spec 022)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (embedding — used in Spec 022)
VOYAGE_API_KEY=pa-...

# Auth secret — for API key verification (use a strong, random string)
HUMETRIC_AUTH_SECRET=change-me-to-a-long-random-secret

# Optional: embedding dimension (default 1024)
HUMETRIC_EMBED_DIM=1024

# Minimum confidence threshold for metric extraction (default 0.55)
HUMETRIC_CONFIDENCE_THRESHOLD=0.55

# BYO-Key encryption — 32-byte hex key for encrypting tenant-provided API keys (Spec 025, optional)
HUMETRIC_ENCRYPTION_KEY=

# Stripe (Spec 026 — billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...

# Set to false to skip email verification: /register auto-activates the
# tenant and returns the API key immediately.
HUMETRIC_REQUIRE_EMAIL_VERIFICATION=true

# Email (Spec 026 — verification, welcome, limit warnings)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=
SMTP_FROM=noreply@humetric.io

# Captcha (Spec 026 — self-service registration)
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# HuMetric base URL (Spec 026 — MCP server, email links)
HUMETRIC_BASE_URL=http://localhost:8002

# MCP server API key (Spec 026)
HUMETRIC_MCP_API_KEY=hu_live_...

# Worker task-type isolation — comma-separated task types this worker process
# claims. Unset = claims every type.
#   worker: signal_process,re_embed,lakehouse_export
# HUMETRIC_WORKER_TASK_TYPES=

# Batch backfill worker (one-shot: python -m humetric.batch_worker)
# HUMETRIC_BATCH_SUBMIT_SIZE=1000
# HUMETRIC_BATCH_POLL_INTERVAL_S=30
# HUMETRIC_BATCH_RECLAIM_S=3600
# Cold-start curator fast-path (skips the Sonnet call when an entity has no
# existing metrics). Opt-in; recommended for backfill runs.
# HUMETRIC_CURATOR_FAST_PATH_ENABLED=false

# Multi-provider BYOK (beta: anthropic only). To enable more providers:
# HUMETRIC_ENABLED_LLM_PROVIDERS=anthropic,openai,google,deepseek
# Per-provider model overrides (defaults shown):
# HUMETRIC_OPENAI_AGENT_MODEL=gpt-4o-mini
# HUMETRIC_OPENAI_CURATOR_MODEL=gpt-4o
# HUMETRIC_OPENAI_RANKER_MODEL=gpt-4o
# HUMETRIC_GOOGLE_AGENT_MODEL=gemini-1.5-flash
# HUMETRIC_GOOGLE_CURATOR_MODEL=gemini-1.5-pro
# HUMETRIC_GOOGLE_RANKER_MODEL=gemini-1.5-pro
# HUMETRIC_DEEPSEEK_AGENT_MODEL=deepseek-chat
# HUMETRIC_DEEPSEEK_CURATOR_MODEL=deepseek-chat
# HUMETRIC_DEEPSEEK_RANKER_MODEL=deepseek-chat

# Embedding provider: voyage (default) | openai | cohere
# HUMETRIC_EMBEDDING_PROVIDER=voyage
# HUMETRIC_OPENAI_API_KEY=
# HUMETRIC_COHERE_API_KEY=
# HUMETRIC_EMBED_DIM_VOYAGE=1024
# HUMETRIC_EMBED_DIM_OPENAI=1536
# HUMETRIC_EMBED_DIM_COHERE=1024

# CORS — comma-separated origins. Defaults to * for local dev; MUST be set to
# the real dashboard origin(s) in production.
# HUMETRIC_CORS_ALLOWED_ORIGINS=https://gethumetric.com,https://www.gethumetric.com

# Analytics lakehouse export (optional — requires pip install 'humetric[analytics]')
# HUMETRIC_EXPORT_ENABLED=false
# HUMETRIC_EXPORT_STORAGE=local          # local | s3
# HUMETRIC_EXPORT_LOCAL_DIR=lakehouse    # relative to project root
# HUMETRIC_EXPORT_HOUR_UTC=2             # hour to trigger nightly export
# HUMETRIC_EXPORT_SCHEDULER_INTERVAL_S=300
# --- S3 / Cloudflare R2 (only needed when EXPORT_STORAGE=s3) ---
# HUMETRIC_EXPORT_S3_BUCKET=
# HUMETRIC_EXPORT_S3_PREFIX=             # optional path prefix inside bucket
# HUMETRIC_EXPORT_S3_ENDPOINT_URL=       # e.g. https://<account>.r2.cloudflarestorage.com
# HUMETRIC_EXPORT_S3_REGION=auto
# HUMETRIC_EXPORT_S3_ACCESS_KEY_ID=
# HUMETRIC_EXPORT_S3_SECRET_ACCESS_KEY=
