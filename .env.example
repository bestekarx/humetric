# PostgreSQL + pgvector (admin role — migration/seed)
DATABASE_URL=postgresql+psycopg://humetric:humetric@localhost:5434/humetric

# PostgreSQL + pgvector (restricted role — runtime, RLS active)
DATABASE_URL_APP=postgresql+psycopg://humetric_app:humetric_app@localhost:5434/humetric

# Anthropic (LLM agents — used in Spec 022)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (embedding — used in Spec 022)
VOYAGE_API_KEY=pa-...

# Auth secret — for API key verification (use a strong, random string)
HUMETRIC_AUTH_SECRET=change-me-to-a-long-random-secret

# Optional: embedding dimension (default 1024)
HUMETRIC_EMBED_DIM=1024

# Minimum confidence threshold for metric extraction (default 0.55)
HUMETRIC_CONFIDENCE_THRESHOLD=0.55

# BYO-Key encryption — 32-byte hex key for encrypting tenant-provided API keys (Spec 025, optional)
HUMETRIC_ENCRYPTION_KEY=

# Stripe (Spec 026 — billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_...

# Email (Spec 026 — verification, welcome, limit warnings)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=
SMTP_FROM=noreply@humetric.io

# Captcha (Spec 026 — self-service registration)
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# HuMetric base URL (Spec 026 — MCP server, email links)
HUMETRIC_BASE_URL=http://localhost:8002

# MCP server API key (Spec 026)
HUMETRIC_MCP_API_KEY=hu_live_...
